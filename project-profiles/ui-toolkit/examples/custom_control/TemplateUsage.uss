.cards {
    flex-direction: row;
    flex-wrap: wrap;
}

.card {
    width: 260px;
    padding: 14px;
    margin: 8px;
    border-radius: 10px;
    background-color: rgba(255, 255, 255, 0.08);
}

.card__title {
    font-size: 20px;
    -unity-font-style: bold;
}

.card__subtitle {
    opacity: 0.65;
    margin-bottom: 8px;
}

#warning-card > .card {
    background-color: rgba(180, 60, 35, 0.25);
}
